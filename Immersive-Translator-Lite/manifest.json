{
  "manifest_version": 3,
  "name": "Immersive Translator Lite",
  "version": "0.0.3",
  "description": "A block-level immersive translator with iframe support, powered by OpenAI Responses, OpenAI Chat Completions, Gemini, and DeepSeek LLM APIs.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Toggle Selection Mode",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-config.js",
        "content-api.js",
        "content-dom.js",
        "content-ui.js",
        "content-script.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
